# =============================================================================
# Boxify Frontend — Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and adjust the values for your environment:
#
#   cp .env.local.example .env.local
#
# Next.js automatically loads `.env.local` on startup.
# All variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# Base URL of the Boxify FastAPI backend (including the /api prefix).
# Change this if your backend runs on a different host or port.
NEXT_PUBLIC_API_URL=http://localhost:8000/api
